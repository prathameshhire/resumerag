# ============================================================
# ResumeRAG — environment variable reference
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your own values, then:
#   docker compose up --build
#
# SECURITY NOTE: .env is git-ignored.  Never commit real
# credentials.  The values below are development defaults
# meant only for running the app locally on your own machine.
# Change passwords before exposing this stack on a network.
# ============================================================

# ── App ─────────────────────────────────────────────────────
# Controls logging verbosity and behaviour flags inside the app.
# Options: development | production
APP_ENV=development

# Port the frontend Vite dev server listens on inside Docker.
# The host-side port mapping mirrors this value.
FRONTEND_PORT=3000

# Port the FastAPI backend listens on inside Docker.
BACKEND_PORT=8000

# ── Database ─────────────────────────────────────────────────
# Credentials for the PostgreSQL/pgvector service.
# All four values must be consistent: POSTGRES_USER/PASSWORD/DB
# are used by the Postgres image to initialise the database,
# while DATABASE_URL is used by the FastAPI backend to connect.
#
# WARNING: DATABASE_URL has no fallback default in config.py —
# if this variable is missing the backend will refuse to start
# with a clear ValidationError rather than connecting silently
# to the wrong host.
#
# Must use the psycopg3 driver scheme: postgresql+psycopg://
# (not the bare postgresql:// scheme — that targets psycopg2).
POSTGRES_USER=resumerag
POSTGRES_PASSWORD=resumerag
POSTGRES_DB=resumerag
DATABASE_URL=postgresql+psycopg://resumerag:resumerag@db:5432/resumerag

# ── Vector / Embedding ───────────────────────────────────────
# HuggingFace model ID for the local sentence-transformers embedding model.
# Changing this requires updating EMBEDDING_DIM to match the model's output
# dimension, and re-indexing all previously uploaded documents.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Output dimension of the embedding model above.  Must match the vector
# column size in the database schema (currently 384 for all-MiniLM-L6-v2).
# Mismatches cause runtime errors during ingestion and search.
EMBEDDING_DIM=384

# Maximum characters per document chunk before splitting.
# Larger values → fewer, richer chunks; smaller values → more granular retrieval.
CHUNK_SIZE_CHARS=2200

# Characters of overlap between adjacent chunks.
# Helps preserve context at chunk boundaries.  Must be < CHUNK_SIZE_CHARS.
CHUNK_OVERLAP_CHARS=300

# Default number of chunks to retrieve per search/tailor request.
# Can be overridden per-request via the API.
RETRIEVAL_TOP_K=8

# Maximum total characters of retrieved context passed to the LLM prompt.
# Increase if you want the LLM to see more evidence; decrease to cut latency.
MAX_PROMPT_CONTEXT_CHARS=12000

# ── Ollama ───────────────────────────────────────────────────
# Base URL of the Ollama server.
# • Mac / Windows Docker:  http://host.docker.internal:11434  (default)
# • Linux Docker:          http://host.docker.internal:11434
#                          (works because docker-compose.yml adds the
#                           host-gateway extra_hosts entry for Linux)
# • Ollama running in Docker on same network: http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Name of the Ollama model to use for bullet generation.
# Run `ollama pull <model>` before starting the stack.
# Recommended: llama3.2 (good balance of speed and quality on 8–16 GB RAM).
# Smaller alternative: llama3.2:3b  (faster, lower quality).
OLLAMA_MODEL=llama3.2

# Seconds before an Ollama generation request is abandoned.
# Increase for large models or slow hardware.
OLLAMA_TIMEOUT_SECONDS=120

# ── Upload limits ────────────────────────────────────────────
# Maximum file size the backend will accept for document uploads (megabytes).
MAX_UPLOAD_MB=20

# Absolute path inside the backend container where uploaded files are stored.
# Backed by the backend_uploads Docker named volume — do not change unless
# you also update the volume mount in docker-compose.yml.
UPLOAD_DIR=/app/uploads

# ── Frontend ─────────────────────────────────────────────────
# URL the browser uses to reach the backend API.
# Must be reachable from the user's machine, not from inside Docker.
# Change to your server's hostname/IP if deploying beyond localhost.
VITE_API_BASE_URL=http://localhost:8000

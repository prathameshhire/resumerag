# App
APP_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Database
POSTGRES_USER=resumerag
POSTGRES_PASSWORD=resumerag
POSTGRES_DB=resumerag
DATABASE_URL=postgresql+psycopg://resumerag:resumerag@db:5432/resumerag

# Vector/Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
CHUNK_SIZE_CHARS=2200
CHUNK_OVERLAP_CHARS=300
RETRIEVAL_TOP_K=8
MAX_PROMPT_CONTEXT_CHARS=12000

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# Upload limits
MAX_UPLOAD_MB=20
UPLOAD_DIR=/app/uploads

# Frontend
VITE_API_BASE_URL=http://localhost:8000
